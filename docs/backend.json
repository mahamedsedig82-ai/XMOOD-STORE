{
  "entities": {
    "UserProfile": {
      "title": "User Profile PRO",
      "description": "Extended user info with multi-level roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "walletBalance": { "type": "number" },
        "role": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string" },
        "lastSeen": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "GlobalSettings": {
      "title": "Global Settings",
      "description": "App configuration and branding",
      "type": "object",
      "properties": {
        "appearance": { "type": "object" },
        "siteInfo": { "type": "object" },
        "cartLabels": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/settings/{id}": {
      "schema": "GlobalSettings",
      "description": "Global configs"
    },
    "/products/{productId}": {
      "schema": "object",
      "description": "Store items"
    },
    "/orders/{orderId}": {
      "schema": "object",
      "description": "Sales records"
    },
    "/transactions/{id}": {
      "schema": "object",
      "description": "Financial ledger"
    },
    "/site_branches/{id}": {
      "schema": "object",
      "description": "Navigation links"
    },
    "/other_services/{id}": {
      "schema": "object",
      "description": "Marketplace services"
    },
    "/gallery/{id}": {
      "schema": "object",
      "description": "Creative portfolio items"
    },
    "/marketplace_listings/{id}": {
      "schema": "object",
      "description": "Community market posts"
    },
    "/community_reports/{id}": {
      "schema": "object",
      "description": "User reports"
    },
    "/community_audit_logs/{id}": {
      "schema": "object",
      "description": "Administrative audit logs"
    }
  }
}