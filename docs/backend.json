
{
  "entities": {
    "UserProfile": {
      "title": "User Profile PRO",
      "description": "Extended user info with multi-level roles and middleman metadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "walletBalance": { "type": "number" },
        "role": { 
          "type": "string", 
          "enum": ["owner", "admin", "gm", "store_manager", "design_manager", "designer", "accountant", "support", "middleman", "agent", "user"] 
        },
        "photoURL": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "affinityPoints": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "bio": { "type": "string" },
        "completedDeals": { "type": "number" },
        "phoneNumber": { "type": "string" },
        "residence": { "type": "string" },
        "middlemanInfo": {
          "type": "object",
          "properties": {
            "services": { "type": "array", "items": { "type": "string" } },
            "isAvailable": { "type": "boolean" },
            "workHours": { "type": "string" }
          }
        }
      },
      "required": ["uid", "email", "role"]
    },
    "GalleryItem": {
      "title": "Gallery Design",
      "description": "A showcase item for the designer portfolio",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "imageUrl"]
    },
    "OtherService": {
      "title": "Professional Service",
      "description": "Managed services offered by agents or the platform",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "agentName": { "type": "string" },
        "agentId": { "type": "string" },
        "whatsapp": { "type": "string" },
        "imageUrl": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "isAvailable": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "whatsapp"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Sovereign user profiles"
    },
    "/gallery/{itemId}": {
      "schema": "GalleryItem",
      "description": "Designer portfolio items"
    },
    "/other_services/{serviceId}": {
      "schema": "OtherService",
      "description": "Managed extra services"
    }
  }
}
