
{
  "entities": {
    "UserProfile": {
      "title": "User Profile PRO",
      "description": "Extended user info with multi-level roles and community status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "walletBalance": { "type": "number" },
        "role": { 
          "type": "string", 
          "enum": ["owner", "admin", "gm", "community_admin", "community_mod", "store_manager", "design_manager", "designer", "accountant", "support", "middleman", "agent", "user"] 
        },
        "isTrusted": { "type": "boolean" },
        "communityStatus": { "type": "string", "enum": ["active", "muted", "banned"] },
        "photoURL": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "affinityPoints": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedDeals": { "type": "number" },
        "phoneNumber": { "type": "string" },
        "residence": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "GlobalSettings": {
      "title": "Global Settings",
      "description": "Central app configurations and labels",
      "type": "object",
      "properties": {
        "siteInfo": { "type": "object" },
        "appearance": { "type": "object" },
        "navLabels": { "type": "object" },
        "cartLabels": { "type": "object" }
      }
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Log of admin actions",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "adminName": { "type": "string" },
        "action": { "type": "string" },
        "targetId": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Sovereign user profiles"
    },
    "/settings/{id}": {
      "schema": "GlobalSettings",
      "description": "Central app configurations"
    },
    "/products/{productId}": {
      "schema": "object",
      "description": "Store items and stock"
    },
    "/orders/{orderId}": {
      "schema": "object",
      "description": "Sales records"
    },
    "/transactions/{id}": {
      "schema": "object",
      "description": "Financial ledger"
    },
    "/gallery/{id}": {
      "schema": "object",
      "description": "Design portfolio"
    },
    "/other_services/{id}": {
      "schema": "object",
      "description": "Professional services"
    },
    "/community_audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Administrative action logs"
    }
  }
}
