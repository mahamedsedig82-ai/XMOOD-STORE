
{
  "entities": {
    "UserProfile": {
      "title": "User Profile PRO",
      "description": "Extended user info with multi-level roles and middleman metadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "walletBalance": { "type": "number" },
        "role": { 
          "type": "string", 
          "enum": ["owner", "admin", "gm", "store_manager", "design_manager", "designer", "accountant", "support", "middleman", "agent", "user"] 
        },
        "photoURL": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "affinityPoints": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "bio": { "type": "string" },
        "completedDeals": { "type": "number" },
        "phoneNumber": { "type": "string" },
        "residence": { "type": "string" },
        "middlemanInfo": {
          "type": "object",
          "properties": {
            "services": { "type": "array", "items": { "type": "string" } },
            "isAvailable": { "type": "boolean" },
            "workHours": { "type": "string" }
          }
        }
      },
      "required": ["uid", "email", "role"]
    },
    "GalleryItem": {
      "title": "Gallery Design",
      "description": "A showcase item for the designer portfolio",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "imageUrl"]
    },
    "AgentRequest": {
      "title": "Agent Request",
      "description": "User application to become a certified charging agent",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "reason": { "type": "string" },
        "experience": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "reason"]
    },
    "MarketplaceListing": {
      "title": "Marketplace Listing",
      "description": "User generated posts with mandatory contact for escrow safety",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string", "enum": ["sell", "buy", "service"] },
        "contactMethod": { "type": "string", "enum": ["whatsapp", "telegram", "email", "onsite"] },
        "contactValue": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "commentCount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "contactMethod", "contactValue"]
    },
    "Comment": {
      "title": "Post Comment",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Sovereign user profiles"
    },
    "/gallery/{itemId}": {
      "schema": "GalleryItem",
      "description": "Designer portfolio items"
    },
    "/agent_requests/{requestId}": {
      "schema": "AgentRequest",
      "description": "Agent applications"
    },
    "/marketplace_listings/{postId}": {
      "schema": "MarketplaceListing",
      "description": "Social marketplace posts"
    },
    "/marketplace_listings/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Post interaction comments"
    }
  }
}
