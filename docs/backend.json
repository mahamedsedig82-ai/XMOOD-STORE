
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information and wallet balance",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "walletBalance": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin", "agent", "vip"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "label": { "type": "string" },
        "isVerified": { "type": "boolean" }
      },
      "required": ["uid", "email", "walletBalance", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Service or item in store/marketplace",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stock": { "type": "number" },
        "shippingCodes": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "out_of_stock", "discount", "inactive"] },
        "vendorId": { "type": "string" }
      },
      "required": ["name", "price", "category", "stock", "status"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global configuration for logo, titles and themes",
      "type": "object",
      "properties": {
        "logoData": { "type": "string" },
        "siteTitle": { "type": "string" },
        "siteSubtitle": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroDescription": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "apple.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Public and private user data"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Catalog of all services and items"
    },
    "/settings/global": {
      "schema": "SiteSettings",
      "description": "Global site configuration"
    }
  }
}
