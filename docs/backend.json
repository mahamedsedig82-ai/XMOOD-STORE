
{
  "entities": {
    "UserProfile": {
      "title": "User Profile PRO",
      "description": "Extended user info with multi-level roles and affinity metrics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "walletBalance": { "type": "number" },
        "role": { 
          "type": "string", 
          "enum": ["owner", "admin", "gm", "store_manager", "design_manager", "designer", "accountant", "support", "middleman", "user"] 
        },
        "photoURL": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "affinityPoints": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "bio": { "type": "string" },
        "completedDeals": { "type": "number" }
      },
      "required": ["uid", "email", "role"]
    },
    "MarketplaceListing": {
      "title": "Marketplace Listing",
      "description": "User generated posts with mandatory contact for escrow safety",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string", "enum": ["sell", "buy", "service"] },
        "contactMethod": { "type": "string", "enum": ["whatsapp", "telegram", "email", "onsite"] },
        "contactValue": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "commentCount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "contactMethod", "contactValue"]
    },
    "Comment": {
      "title": "Post Comment",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "MiddlemanRequest": {
      "title": "Middleman Request",
      "type": "object",
      "properties": {
        "listingId": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "middlemanId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "completed", "cancelled"] },
        "amount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Sovereign user profiles"
    },
    "/marketplace_listings/{postId}": {
      "schema": "MarketplaceListing",
      "description": "Social marketplace posts"
    },
    "/marketplace_listings/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Post interaction comments"
    },
    "/middleman_requests/{requestId}": {
      "schema": "MiddlemanRequest",
      "description": "Escrow transaction tracking"
    }
  }
}
