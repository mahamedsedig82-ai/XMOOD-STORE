{
  "entities": {
    "UserProfile": {
      "title": "User Profile PRO",
      "description": "Extended user info with multi-level roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "walletBalance": { "type": "number" },
        "role": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "object",
      "description": "Store items"
    },
    "/orders/{orderId}": {
      "schema": "object",
      "description": "Sales records"
    },
    "/settings/{id}": {
      "schema": "object",
      "description": "Global configs"
    },
    "/transactions/{id}": {
      "schema": "object",
      "description": "Financial ledger"
    },
    "/site_branches/{id}": {
      "schema": "object",
      "description": "Navigation links"
    }
  }
}
