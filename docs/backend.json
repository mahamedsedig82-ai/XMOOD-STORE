
{
  "entities": {
    "UserProfile": {
      "title": "User Profile PRO",
      "description": "Extended user info with multi-level roles and affinity metrics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "walletBalance": { "type": "number" },
        "role": { 
          "type": "string", 
          "enum": ["owner", "admin", "gm", "store_manager", "design_manager", "designer", "accountant", "support", "middleman", "user"] 
        },
        "photoURL": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "affinityPoints": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "DesignRequest": {
      "title": "Design Request",
      "description": "Professional design workflow tracking",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerEmail": { "type": "string" },
        "designType": { "type": "string" },
        "description": { "type": "string" },
        "colors": { "type": "string" },
        "dimensions": { "type": "string" },
        "attachments": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "assigned", "drafting", "review", "completed", "cancelled"] },
        "assignedTo": { "type": "string" },
        "drafts": { "type": "array", "items": { "type": "string" } },
        "finalFiles": { "type": "array", "items": { "type": "string" } },
        "price": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AppConfiguration": {
      "title": "App Configuration",
      "description": "Global visual and system settings",
      "type": "object",
      "properties": {
        "appearance": {
          "type": "object",
          "properties": {
            "primaryColor": { "type": "string" },
            "backgroundColor": { "type": "string" },
            "fontFamily": { "type": "string" },
            "logoUrl": { "type": "string" }
          }
        },
        "siteInfo": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "heroTitle": { "type": "string" },
            "heroDescription": { "type": "string" }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "apple.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Sovereign user profiles"
    },
    "/design_requests/{requestId}": {
      "schema": "DesignRequest",
      "description": "Design workflow tasks"
    },
    "/settings/global": {
      "schema": "AppConfiguration",
      "description": "Dynamic app settings"
    }
  }
}
