
{
  "entities": {
    "UserProfile": {
      "title": "User Profile PRO",
      "description": "Extended user info with multi-level roles and community status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "walletBalance": { "type": "number" },
        "role": { 
          "type": "string", 
          "enum": ["owner", "admin", "gm", "community_admin", "community_mod", "store_manager", "design_manager", "designer", "accountant", "support", "middleman", "agent", "user"] 
        },
        "isTrusted": { "type": "boolean" },
        "communityStatus": { "type": "string", "enum": ["active", "muted", "banned"] },
        "photoURL": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "affinityPoints": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedDeals": { "type": "number" },
        "phoneNumber": { "type": "string" },
        "residence": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "MarketplaceListing": {
      "title": "Community Post",
      "description": "A post in the community marketplace",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string", "enum": ["sell", "buy", "service"] },
        "status": { "type": "string", "enum": ["active", "hidden", "deleted"] },
        "isVerifiedPost": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CommunityReport": {
      "title": "Report",
      "description": "User report for content violation",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string" },
        "targetId": { "type": "string" },
        "targetType": { "type": "string", "enum": ["post", "comment", "user"] },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved", "dismissed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Log of admin actions",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "adminName": { "type": "string" },
        "action": { "type": "string" },
        "targetId": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Sovereign user profiles"
    },
    "/marketplace_listings/{postId}": {
      "schema": "MarketplaceListing",
      "description": "Community marketplace posts"
    },
    "/community_reports/{reportId}": {
      "schema": "CommunityReport",
      "description": "User violation reports"
    },
    "/community_audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Administrative action logs"
    }
  }
}
